# ─── EduManage Next.js Frontend ───────────────────────────────────
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_NAME=FlexiSoftwareEduApp
NEXT_PUBLIC_APP_VERSION=1.0.0

# PayStack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_a9c283c40d4657aeafd45f302af06878367c03f7

# Development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Staging / Production: replace with your actual domain
# NEXT_PUBLIC_API_URL=https://api.flexierp.com/api


# The URL(s) of your Next.js frontend.
# For multiple domains separate them with commas (no spaces):
#   FRONTEND_URLS=https://app.flexierp.com,https://staging.flexierp.com
FRONTEND_URLS=http://localhost:3000

# Sanctum: how long (in minutes) a token stays valid after issuance.
# 7 days = 10080 minutes
SANCTUM_TOKEN_EXPIRATION=10080

# Database – fill in your actual values
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flexi_edu_app
DB_USERNAME=root
DB_PASSWORD=

# App
APP_NAME=FlexiERP
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
